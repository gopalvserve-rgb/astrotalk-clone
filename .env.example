# ========================
# AstroTalk Clone — env
# ========================

# Node env
NODE_ENV=development

# Master DB — stores tenants registry + auth (shared across tenants)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astrotalk_master

# Per-tenant DB connection string template
# {tenantId} will be replaced at runtime
TENANT_DATABASE_URL_TEMPLATE=postgresql://postgres:postgres@localhost:5432/astrotalk_tenant_{tenantId}

# Auth
NEXTAUTH_SECRET=replace-me-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=replace-me-with-another-long-random-string

# OTP provider (use any: MSG91, Twilio, etc.)
OTP_PROVIDER=msg91
MSG91_AUTH_KEY=
MSG91_SENDER=ASTRTK
MSG91_TEMPLATE_ID=

# Redis (sessions, OTP cache, rate limit, BullMQ)
REDIS_URL=redis://localhost:6379

# =========
# Cashfree
# =========
CASHFREE_ENV=TEST                     # TEST or PROD
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
# Payouts (for astrologer settlements)
CASHFREE_PAYOUT_CLIENT_ID=
CASHFREE_PAYOUT_CLIENT_SECRET=

# =========
# AI providers
# =========
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
AI_DAILY_USD_CAP_PER_USER=2.00

# =========
# Storage (S3-compatible — Cloudflare R2 recommended)
# =========
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=astrotalk-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=https://cdn.your-domain.com

# =========
# Real-time (Agora for voice/video, Socket.IO server for chat)
# =========
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Optional — Twilio SMS fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Email (transactional)
RESEND_API_KEY=
EMAIL_FROM=no-reply@your-domain.com

# Admin bootstrap (super admin for the master DB)
SUPER_ADMIN_EMAIL=admin@your-domain.com
SUPER_ADMIN_PASSWORD=ChangeMe!1234
